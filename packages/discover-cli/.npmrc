;;
;; ╔══════════════════════════════════════════════════════════════════════╗
;; ║  ⚠️  DO NOT PASTE ANY TOKEN INTO THIS FILE  ⚠️                       ║
;; ║                                                                      ║
;; ║  ${NPM_TOKEN} below is INTENTIONAL — npm reads it from your shell    ║
;; ║  environment at publish time. The actual token NEVER lives on disk.  ║
;; ║                                                                      ║
;; ║  Correct usage (run from this directory):                            ║
;; ║                                                                      ║
;; ║      NPM_TOKEN=npm_yourrealtoken npm publish                         ║
;; ║                                                                      ║
;; ║  WRONG: pasting `npm_xxx...` inside ${...} — that breaks auth AND    ║
;; ║         leaks the token into a tracked file. If you ever do that,    ║
;; ║         REVOKE that token at npmjs.com/settings/<you>/tokens.        ║
;; ╚══════════════════════════════════════════════════════════════════════╝
;;

registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
access=public
