# ─────────────────────────────────────────────────────────────────────
# ERC-8004 contracts — deploy environment
# ─────────────────────────────────────────────────────────────────────
# 1. Copy this file:    cp .env.example .env
# 2. Fill in real values (see "How to get this" notes for each var)
# 3. NEVER commit .env  (it's gitignored at the repo root via *.local
#    and our explicit rules — see /.gitignore)
# ─────────────────────────────────────────────────────────────────────


# ─── DEPLOYER_PRIVATE_KEY ────────────────────────────────────────────
# Private key (with 0x prefix) of the wallet that deploys + owns these
# contracts on Base Sepolia / Base mainnet.
#
# How to get this:
#   • For TESTNET: generate a brand-new wallet just for testing.
#       cast wallet new            # Foundry built-in
#     OR in MetaMask: create a new account → Account details → Show
#     private key. This account should hold ONLY testnet funds.
#   • For MAINNET: NEVER paste a mainnet private key into a .env file.
#     Use a hardware wallet via `--ledger` / `--trezor` flags on
#     `forge script`, or use Foundry keystores (`cast wallet import`).
#
# Get Base Sepolia ETH (free): https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY


# ─── BASE_SEPOLIA_RPC_URL ────────────────────────────────────────────
# JSON-RPC endpoint for Base Sepolia testnet (chainId 84532).
#
# How to get this — pick ONE:
#   • Free public:    https://sepolia.base.org
#       (rate-limited, fine for occasional deploys)
#   • Alchemy (free): https://www.alchemy.com/ → create app → Base
#                     Sepolia → copy HTTPS URL (better reliability)
#   • QuickNode:      https://www.quicknode.com/ → Base Sepolia node
#   • Infura:         https://infura.io/ → Base Sepolia endpoint
#
# Default works for one-off deploys; switch to a personal endpoint if
# you hit rate limits.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org


# ─── BASE_MAINNET_RPC_URL ────────────────────────────────────────────
# JSON-RPC endpoint for Base mainnet (chainId 8453). Same providers as
# above, just pick the "Base mainnet" network.
#
# Free public:        https://mainnet.base.org
# Recommended:        Alchemy / QuickNode / Infura paid tier for
#                     production deploys.
BASE_MAINNET_RPC_URL=https://mainnet.base.org


# ─── BASESCAN_API_KEY ────────────────────────────────────────────────
# API key for Basescan contract verification. Same key works for both
# Base Sepolia and Base mainnet.
#
# How to get this (free, ~30 seconds):
#   1. Go to https://basescan.org/myapikey
#   2. Create an account (or sign in)
#   3. Click "Add" to create a new API key
#   4. Copy the "Api-Key Token" value here
#
# WHY YOU WANT THIS: with the key set, `forge script ... --verify`
# automatically verifies the contract source on Basescan day-of, which
# is required before any merchant trusts the deploy.
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY


# ─── BOOKING_ESCROW_PLACEHOLDER ──────────────────────────────────────
# (Phase A.2 only — Phase B will replace this with the real escrow.)
#
# ReputationRegistry's constructor requires a non-zero booking-escrow
# address. Phase B (BookingEscrow.sol) hasn't shipped yet, so we use a
# burn address as a placeholder. The placeholder is unreachable, so
# `autoAuthorizeFromBooking()` simply can't be called until Phase B.
#
# When Phase B ships:
#   • Deploy the real BookingEscrow.sol
#   • REDEPLOY ReputationRegistry pointing at the real address
#     (clean-slate over backward-compat per Principle 4)
#
# Default 0x...dEaD is fine; only change if you have a specific reason.
BOOKING_ESCROW_PLACEHOLDER=0x000000000000000000000000000000000000dEaD
